{
  "routes": [
    { "handle": "filesystem" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/imgs/(.*)", "dest": "/imgs/$1" },
    { "src": "/dist/(.*)", "dest": "/dist/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
